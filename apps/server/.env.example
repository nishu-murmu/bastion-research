# Server Configuration
PORT=
API_BASE_URL=

# JWT with Google
JWT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Cashfree PG
CASHFREE_ENV=
CASHFREE_APP_ID=
CASHFREE_SECRET=
CASHFREE_VERIFICATION_CLIENT_ID=
CASHFREE_VERIFICATION_CLIENT_SECRET=
CASHFREE_VERIFICATION_API_VERSION=

# Optional override for express.json limit (defaults to 5mb)
BODY_PARSER_LIMIT=


FRONTEND_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
MAX_IMAGE_FILE_SIZE=

# SMTP (for sending password reset emails)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=

# Zoho Books
# Your Zoho Books organization ID (e.g. 907181255)
ZOHO_BOOKS_ORGANIZATION_ID=
# Zoho Accounts base URL for your region (e.g. https://accounts.zoho.in)
ZOHO_BOOKS_ACCOUNTS_BASE_URL=
# Zoho API domain for your region (e.g. https://www.zohoapis.in)
ZOHO_BOOKS_API_DOMAIN=
# OAuth client credentials and refresh token
ZOHO_BOOKS_CLIENT_ID=
ZOHO_BOOKS_CLIENT_SECRET=
ZOHO_BOOKS_REFRESH_TOKEN=
# Optional legacy static access token (used only if refresh flow is not configured)
ZOHO_BOOKS_ACCESS_TOKEN=
