# Server Configuration
PORT=
API_BASE_URL=

# JWT with Google
JWT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Cashfree PG
CASHFREE_ENV=
CASHFREE_APP_ID=
CASHFREE_SECRET=
CASHFREE_VERIFICATION_CLIENT_ID=
CASHFREE_VERIFICATION_CLIENT_SECRET=
CASHFREE_VERIFICATION_API_VERSION=

# Optional override for express.json limit (defaults to 5mb)
BODY_PARSER_LIMIT=


# Comma-separated list of allowed frontend origins, e.g. https://example.com,https://www.example.com
FRONTEND_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
MAX_IMAGE_FILE_SIZE=

# AiSensy WhatsApp (API Campaigns)
AISENSY_API_KEY=
# Optional if campaign name is set in Admin → Settings (Webinar — AiSensy)
AISENSY_CAMPAIGN_NAME=
# Optional: comma-separated list of template param keys (supported: name,email,phone,webinar_slug)
AISENSY_TEMPLATE_PARAMS=

# Mailchimp — optional merge tags for webinar date/time (Admin → Settings values)
# Must match merge field tags in your Mailchimp audience (e.g. MMERGE7)
MAILCHIMP_WEBINAR_DATE_MERGE_TAG=
MAILCHIMP_WEBINAR_TIME_MERGE_TAG=

# SMTP (Hostinger and similar: From must match the authenticated mailbox — see SMTP_FROM)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
# Optional: overrides CONNECT_EMAIL for the envelope From when it matches SMTP_USERNAME
SMTP_FROM=
# Public-facing sender (must equal SMTP_USERNAME on Hostinger unless using that mailbox’s credentials)
CONNECT_EMAIL=
LEADS_EMAIL=