# Server Configuration
PORT=3001
API_BASE_URL=http://localhost:3001

# DIGIO 
DIGIO_BASE_URL=
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=

# DIGIO Debugging
DIGIO_DISABLED=

# DIGIO Webhook
# Set this to the Group Secret from Digio Webhook Group settings
DIGIO_WEBHOOK_SECRET=
# If true, reject requests with missing/invalid signature
DIGIO_WEBHOOK_REQUIRE_SIGNATURE=false

# JWT with Google
JWT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Cashfree PG
CASHFREE_ENV=
CASHFREE_APP_ID=
CASHFREE_SECRET=


FRONTEND_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMTP (for sending password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
